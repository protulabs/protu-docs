---
import type { Props } from '@astrojs/starlight/props';
---

<header class="header">
  <div class="header-content">
    <div class="header-left">
      <a href="/" class="site-title-link">
        <img src="/protu-wordmark.svg" alt="protu" class="logo-wordmark" />
        <span class="divider">|</span>
        <span class="docs-label">Docs</span>
      </a>
    </div>
    <div class="header-right">
      <a href="/support/contact/" class="nav-link">Contact us</a>
      <a href="https://app.protu.io" class="signin-button">Sign in</a>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: #0B0E12;
    border-bottom: 1px solid #1E2228;
    padding: 0 3.5rem;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 100%;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-title-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-wordmark {
    height: 20px;
    width: auto;
  }

  .divider {
    color: #3A4250;
    font-size: 1rem;
    font-weight: 300;
  }

  .docs-label {
    color: #EFF3F4;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0;
  }


  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem; /* 16px */
  }

  .nav-link {
    color: #EFF3F4;
    font-size: 0.875rem; /* 14px */
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s ease;
    height: 34px;
    display: flex;
    align-items: center;
    padding: 0 0.75rem;
    border-radius: 6px;
  }

  .nav-link:hover {
    background-color: #191E27;
  }

  .signin-button {
    background-color: #EFF3F4;
    border: none;
    border-radius: 6px;
    padding: 0 0.75rem; /* 12px left/right */
    height: 34px;
    display: flex;
    align-items: center;
    color: #0B0E12;
    font-size: 0.875rem; /* 14px */
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .signin-button:hover {
    background-color: #E4EEF0;
    color: #0B0E12;
  }

  @media (max-width: 50rem) {
    .header {
      padding: 0 1rem;
    }

    .search-container {
      display: none;
    }
  }
</style>
