---
import type { Props } from '@astrojs/starlight/props';
import Search from '@astrojs/starlight/components/Search.astro';
---

<header class="header">
  <div class="header-content">
    <div class="header-left">
      <a href="/" class="site-title-link">
        <img src="/protu-wordmark.svg" alt="protu" class="logo-wordmark" />
        <span class="divider">|</span>
        <span class="docs-label">Docs</span>
      </a>
      <div class="search-container">
        <Search {...Astro.props} />
      </div>
    </div>
    <div class="header-right">
      <a href="https://app.protu.io" class="signin-button">Sign in</a>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: #0B0E12;
    border-bottom: 1px solid #1E2228;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 100%;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-title-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-wordmark {
    height: 16px;
    width: auto;
  }

  .divider {
    color: #3A4250;
    font-size: 1rem;
    font-weight: 300;
  }

  .docs-label {
    color: #EFF3F4;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0;
  }

  .search-container {
    margin-left: 0.5rem;
  }

  .search-container :global(button[data-open-modal]) {
    background-color: transparent;
    border: 1px solid #1E2228;
    border-radius: 6px;
    padding: 0.375rem 0.75rem;
    color: #5A6475;
    font-size: 0.8125rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .search-container :global(button[data-open-modal]:hover) {
    border-color: #252A31;
    color: #939FAD;
  }

  .header-right {
    display: flex;
    align-items: center;
  }

  .signin-button {
    background-color: transparent;
    border: 1px solid #1E2228;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    color: #EFF3F4;
    font-size: 0.8125rem;
    font-weight: 400;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .signin-button:hover {
    background-color: #1E2228;
    border-color: #252A31;
  }

  @media (max-width: 50rem) {
    .header {
      padding: 0 1rem;
    }

    .search-container {
      display: none;
    }
  }
</style>
