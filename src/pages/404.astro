<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found — Protu Docs</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style>
      @font-face {
        font-family: 'Space Grotesk';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('https://fonts.gstatic.com/s/spacegrotesk/v16/V8mDoQDjQSkFtoMM3T6r8E7mPbF4C_k.woff2') format('woff2');
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
        background-color: #0B0E12;
        color: #8A8F9E;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
      }

      .wordmark {
        height: 20px;
        width: auto;
        margin-bottom: 3rem;
        opacity: 0.6;
      }

      .code {
        font-size: 4rem;
        font-weight: 500;
        color: #E8E8EC;
        line-height: 1;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .message {
        font-size: 1rem;
        color: #5C6370;
        margin-bottom: 2.5rem;
        line-height: 1.6;
      }

      .link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #8A8F9E;
        font-size: 0.875rem;
        text-decoration: none;
        border: 1px solid #1E2228;
        border-radius: 6px;
        padding: 0.5rem 1.25rem;
        transition: all 0.15s ease;
      }

      .link:hover {
        color: #E8E8EC;
        border-color: #252A31;
        background-color: #1E2228;
      }
    </style>
  </head>
  <body>
    <img src="/protu-wordmark.svg" alt="Protu" class="wordmark" />
    <div class="code">404</div>
    <p class="message">This page could not be found.</p>
    <a href="/" class="link">&larr; Back to docs</a>
  </body>
</html>
